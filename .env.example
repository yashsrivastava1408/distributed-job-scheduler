# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_scheduler

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# API Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# Worker
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=2000
WORKER_QUEUES=default

# Scheduler Daemon
SCHEDULER_POLL_INTERVAL_MS=5000

# Reaper (crashed worker recovery)
REAPER_POLL_INTERVAL_MS=15000
REAPER_STALE_THRESHOLD_MS=30000
